# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb+srv://sharmaishaan0009_db_user:ghHUPRzUEAcDn8jM@cluster0.zfdetgp.mongodb.net/user

# JWT Configuration
